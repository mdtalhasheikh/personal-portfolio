# Get a key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Optional. Defaults to openai/gpt-oss-120b when unset.
OPENROUTER_MODEL=openai/gpt-oss-120b

# Used for OpenRouter attribution headers and absolute metadata URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. POST endpoint for forwarding contact form submissions.
CONTACT_WEBHOOK_URL=
